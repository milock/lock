# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Public base URL (canonical URLs, sitemap, OG, llms.txt). Optional in dev;
# defaults to https://michael-lock.com.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# GitHub handle whose public repo stars are summed for the "GitHub Stars" tile.
GITHUB_USERNAME=your-github-username

# Optional. A read-only (no-scope) GitHub token only raises the API rate limit;
# public stars resolve fine without it. Set in Vercel if the tile starts 403ing.
# GITHUB_TOKEN=

# Server-only key for the chatbot route (app/api/chat). Get one at
# console.anthropic.com. IMPORTANT: set a monthly spend limit on the key.
ANTHROPIC_API_KEY=
